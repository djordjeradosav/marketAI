{
  "expo": {
    "name": "marketAI",
    "slug": "market-ai",
    "version": "1.0.0",
    "scheme": "marketai",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "splash": { "backgroundColor": "#080c10" },
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.market.ai" },
    "android": { "package": "com.market.ai", "adaptiveIcon": { "backgroundColor": "#080c10" } },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": { "typedRoutes": true },
    "extra": { "router": { "origin": false } },
    "newArchEnabled": true
  }
}